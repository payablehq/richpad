{
  "name": "@payablehq/richpad",
  "version": "1.0.1",
  "description": "Enterprise-grade rich text editor component built with Tiptap, React, and TypeScript.",
  "keywords": [
    "rich-text-editor",
    "tiptap",
    "react",
    "wysiwyg",
    "editor",
    "richpad",
    "payablehq"
  ],
  "author": "PayableHQ",
  "license": "MIT",
  "homepage": "https://payablehq.github.io/richpad",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/payablehq/richpad.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/payablehq"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.6.0",
  "bugs": {
    "url": "https://github.com/payablehq/richpad/issues"
  },
  "type": "module",
  "main": "./dist/richpad.cjs",
  "module": "./dist/richpad.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/richpad.js",
      "require": "./dist/richpad.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./styles": {
      "types": "./dist/richpad.css.d.ts",
      "default": "./dist/richpad.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "BUILD_MODE=lib vite build && tsc -p tsconfig.lib.json && echo 'export {};' > dist/richpad.css.d.ts",
    "build:demo": "BUILD_MODE=demo vite build",
    "build": "npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-mention": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.11",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.21.0",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
